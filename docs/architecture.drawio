          <mxGeometry x="360" y="425" width="280" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="repair-steps" value="1. 结构硬错误 → 启用 PlanRepairer&lt;br&gt;2. 断开告警可选连接子图&lt;br&gt;3. VAL 失败 → LLM 修复计划&lt;br&gt;4. 累积 repair_history&lt;br&gt;5. 最多 max_retries 次 (默认 3 次)" style="text;html=1;align=left;verticalAlign=top;strokeColor=none;fillColor=none;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="370" y="465" width="260" height="90" as="geometry"/>
        </mxCell>

