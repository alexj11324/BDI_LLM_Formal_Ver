# Caches & compiled / temp artifacts (recursive — root-only *.py[cod] etc. do not cover subdirs)
# Dirs: common cache roots (avoid *cache* in filenames — e.g. repair_cache.py stays tracked)
.cache/
**/.cache/
**/cache/
**/*_cache/

# Cache-like / checkpoint extensions
**/*.cache
**/*.cache.*
**/*.npy
**/*.npz
**/*.nbc
**/*.nbi

# ML / notebook / tooling caches
**/.ipynb_checkpoints/
**/.mypy_cache/
**/.ruff_cache/
**/.hypothesis/
**/.tox/
**/.nox/
**/.pyre/
**/.dvc/cache/
**/wandb/
**/lightning_logs/
**/tensorboard/
**/tb_logs/

# Bytecode / compiled (nested paths)
**/*.py[cod]
**/*.class
**/*.o
**/*.so
**/*.dylib

# Temp / partial / swap / backup suffixes
**/*.tmp
**/*.temp
**/*.bak
**/*.old
**/*.orig
**/*.part
**/*.crdownload
**/*.swp
**/*.swo
**/*~

# Dot-prefixed hidden files/dirs (default: ignore all; un-ignore tracked essentials below)
.*
**/.[!.]*
!.gitignore
!.github/
!.github/**
!.env.example
!.env.test

